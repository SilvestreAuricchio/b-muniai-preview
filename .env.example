# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI: https://localhost/bff/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret for Flask session signing and JWT
BFF_SECRET_KEY=change-me-to-a-long-random-string

# SMTP — OTP email delivery (otp-dispatcher service)
# Works with Gmail (use an App Password), SendGrid, or any STARTTLS server.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=MuniAI <your-email@gmail.com>
